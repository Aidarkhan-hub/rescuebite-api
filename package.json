{
  "name": "rescuebite-backend",
  "version": "1.0.0",
  "description": "RescueBite — Real-time food waste recovery marketplace",
  "main": "dist/server.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
