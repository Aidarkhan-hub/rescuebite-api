generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ================================================================
// ENUMS
// ================================================================

enum Role {
  RECIPIENT
  DONOR
  DRIVER
  ADMIN
}

enum FoodStatus {
  FRESH
  DISCOUNTED
  FREE
  COMPOST
}

enum Allergen {
  GLUTEN
  CRUSTACEANS
  EGGS
  FISH
  PEANUTS
  SOY
  DAIRY
  NUTS
  CELERY
  MUSTARD
  SESAME
  SULPHITES
  LUPIN
  MOLLUSCS
}

enum ReservationStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
}

enum OrderStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum AuctionStatus {
  ACTIVE
  COMPLETED
  CANCELLED
}

// ================================================================
// MODELS
// ================================================================

model User {
  id               String  @id @default(uuid()) @db.Uuid
  email            String  @unique @db.VarChar(254)
  name             String  @db.VarChar(120)
  passwordHash     String  @db.VarChar(72)
  role             Role    @default(RECIPIENT)
  isActive         Boolean @default(true)
  refreshTokenHash String?

  // Email verification
  isEmailVerified        Boolean   @default(false)
  emailVerificationToken String?   @db.VarChar(255)

  // Password reset
  passwordResetToken     String?   @db.VarChar(255)
  passwordResetExpiresAt DateTime?

  // Relations
  allergenExclusions UserAllergenExclusion[]
  reservations       Reservation[]
  restaurants        Restaurant[]            // DONOR owns restaurants
  ordersAsDriver     Order[]                 // DRIVER delivers orders
  ratings            Rating[]               // RECIPIENT rates restaurants
  auctionBids        AuctionBid[]           // DRIVER bids in auctions
  auditLogs          AuditLog[]             // actions performed by this user

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([role])
  @@map("users")
}

model UserAllergenExclusion {
  userId   String   @db.Uuid
  allergen Allergen
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, allergen])
  @@map("user_allergen_exclusions")
}

// ================================================================
// RESTAURANT
// ================================================================

model Restaurant {
  id          String  @id @default(uuid()) @db.Uuid
  name        String  @db.VarChar(200)
  address     String  @db.VarChar(500)
  locationLat Float
  locationLng Float
  closingTime String  @db.VarChar(5)  // e.g. "22:00"
  isApproved  Boolean @default(false)
  rating      Float   @default(0)
  ownerId     String  @db.Uuid

  // Relations
  owner    User      @relation(fields: [ownerId], references: [id])
  foodBags FoodBag[]
  ratings  Rating[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([ownerId])
  @@index([isApproved])
  @@map("restaurants")
}

// ================================================================
// FOOD BAG
// ================================================================

model FoodBag {
  id                 String     @id @default(uuid()) @db.Uuid
  title              String     @db.VarChar(200)
  description        String?    @db.Text
  originalPriceCents Int
  currentPriceCents  Int
  quantity           Int        @default(1)
  status             FoodStatus @default(FRESH)
  pickupDeadline     DateTime
  publishedAt        DateTime?
  restaurantId       String?    @db.Uuid  // optional: linked to restaurant

  // Relations
  allergens    FoodBagAllergen[]
  reservations Reservation[]
  restaurant   Restaurant?       @relation(fields: [restaurantId], references: [id])
  auctions     Auction[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status, pickupDeadline])
  @@index([restaurantId])
  @@map("food_bags")
}

model FoodBagAllergen {
  foodBagId String   @db.Uuid
  allergen  Allergen
  foodBag   FoodBag  @relation(fields: [foodBagId], references: [id], onDelete: Cascade)

  @@id([foodBagId, allergen])
  @@map("food_bag_allergens")
}

// ================================================================
// RESERVATION
// ================================================================

model Reservation {
  id             String            @id @default(uuid()) @db.Uuid
  foodBagId      String            @db.Uuid
  userId         String            @db.Uuid
  pricePaidCents Int
  status         ReservationStatus @default(PENDING)

  foodBag FoodBag @relation(fields: [foodBagId], references: [id])
  user    User    @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([foodBagId])
  @@map("reservations")
}

// ================================================================
// ORDER (for DRIVER delivery flow)
// ================================================================

model Order {
  id           String      @id @default(uuid()) @db.Uuid
  reservationId String     @unique @db.Uuid
  driverId     String?     @db.Uuid
  status       OrderStatus @default(PENDING)
  deliveryLat  Float?      // destination coordinates
  deliveryLng  Float?

  driver      User?       @relation(fields: [driverId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([driverId])
  @@index([status])
  @@map("orders")
}

// ================================================================
// FLASH AUCTION
// ================================================================

model Auction {
  id         String        @id @default(uuid()) @db.Uuid
  foodBagId  String        @db.Uuid
  status     AuctionStatus @default(ACTIVE)
  startedAt  DateTime      @default(now())
  endsAt     DateTime

  foodBag FoodBag      @relation(fields: [foodBagId], references: [id])
  bids    AuctionBid[]

  @@index([status])
  @@index([foodBagId])
  @@map("auctions")
}

model AuctionBid {
  id        String @id @default(uuid()) @db.Uuid
  auctionId String @db.Uuid
  driverId  String @db.Uuid
  bidAmount Int    // in cents

  auction Auction @relation(fields: [auctionId], references: [id])
  driver  User    @relation(fields: [driverId], references: [id])

  createdAt DateTime @default(now())

  @@index([auctionId])
  @@index([driverId])
  @@map("auction_bids")
}

// ================================================================
// RATING
// ================================================================

model Rating {
  id           String @id @default(uuid()) @db.Uuid
  userId       String @db.Uuid
  restaurantId String @db.Uuid
  score        Int    // 1-5

  user       User       @relation(fields: [userId], references: [id])
  restaurant Restaurant @relation(fields: [restaurantId], references: [id])

  createdAt DateTime @default(now())

  @@unique([userId, restaurantId]) // one rating per user per restaurant
  @@index([restaurantId])
  @@map("ratings")
}

// ================================================================
// AUDIT LOG
// ================================================================

model AuditLog {
  id         String @id @default(uuid()) @db.Uuid
  actorId    String @db.Uuid        // who performed the action
  action     String @db.VarChar(100) // e.g. "TOGGLE_USER", "APPROVE_RESTAURANT"
  targetType String @db.VarChar(50)  // e.g. "User", "Restaurant"
  targetId   String @db.Uuid        // ID of affected entity
  metadata   Json?                  // extra info

  actor User @relation(fields: [actorId], references: [id])

  createdAt DateTime @default(now())

  @@index([actorId])
  @@index([action])
  @@index([targetId])
  @@map("audit_logs")
}
